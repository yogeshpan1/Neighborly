CREATE TABLE users (
    user_id INT AUTO_INCREMENT PRIMARY KEY,
    first_name VARCHAR(50) NOT NULL,
    last_name VARCHAR(50) NOT NULL,
    username VARCHAR(50) NOT NULL UNIQUE,
    dob DATE NOT NULL,
    gender ENUM('Male', 'Female', 'Other') NOT NULL,
    email VARCHAR(100) NOT NULL UNIQUE,
    number VARCHAR(20) NOT NULL,
    password VARCHAR(255) NOT NULL,
    role ENUM('admin', 'citizen') DEFAULT 'citizen',
    registration_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE polls (
    poll_id INT AUTO_INCREMENT PRIMARY KEY,
    poll_question VARCHAR(255) NOT NULL,
    poll_description TEXT,
    poll_option1 VARCHAR(100) NOT NULL,
    poll_option2 VARCHAR(100) NOT NULL,
    poll_status VARCHAR(50) DEFAULT 'Active',
    poll_created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    admin_id INT NOT NULL,
    FOREIGN KEY (admin_id) REFERENCES admins(admin_id)
);
